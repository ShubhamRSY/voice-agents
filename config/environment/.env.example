# ═══════════════════════════════════════════════════════════════
# Nexus · Enterprise Voice & Chat AI Agents — Environment Config
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp config/environment/.env.example config/environment/.env
# ═══════════════════════════════════════════════════════════════

# ── LLM Providers ─────────────────────────────────────────────
# At least one LLM API key is required for production.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# ── Twilio Telephony (voice) ──────────────────────────────────
# Required for PSTN voice support. Set up at https://twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# Public HTTPS URL for Twilio webhooks (use ngrok in dev, your domain in prod)
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# ── Vector DB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small

# ── Production Database (PostgreSQL) ──────────────────────────
# Leave empty to use SQLite (development only).
# For production, use a managed PostgreSQL instance or the
# docker-compose.yml postgres service:
#   postgresql://nexus:nexus@postgres:5432/nexus
DATABASE_URL=postgresql://nexus:nexus@postgres:5432/nexus

# ── Production Cache & Task Queue (Redis) ─────────────────────
# Leave empty to use in-memory cache/queue (development only).
# For production, use a managed Redis instance or the
# docker-compose.yml redis service:
#   redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# ── Observability ─────────────────────────────────────────────
# Sentry error tracking — https://sentry.io
SENTRY_DSN=https://key@oXXX.ingest.us.sentry.io/YYY
# OpenTelemetry endpoint (e.g., Grafana Tempo, Jaeger, Datadog)
OTEL_ENDPOINT=http://otel-collector:4317

# ── CRM Integration ───────────────────────────────────────────
CRM_PROVIDER=hubspot
HUBSPOT_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ── Encrypted Integrations Vault ──────────────────────────────
# Generate a Fernet key for data/integrations.vault:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production for stable credential decryption.
INTEGRATIONS_ENCRYPTION_KEY=
# Optional: require this token in X-Settings-Token header when
# saving credentials via API or UI.
SETTINGS_ADMIN_TOKEN=
# Optional: HMAC secret for signing outbound n8n/Zapier webhook payloads.
WEBHOOK_SIGNING_SECRET=

# ── HashiCorp Vault (optional) ────────────────────────────────
# If configured, secrets from Vault KV v2 engine will override
# .env values and local encrypted vault. Requires: pip install hvac
VAULT_ADDR=https://vault.example.com:8200
VAULT_TOKEN=hvs...
VAULT_PATH=secret/data/nexus

# ── Logging ───────────────────────────────────────────────────
# Sink: "stdout" (default, pretty-print for dev), "file" (JSON to disk),
#       or "loki" (push to Grafana Loki)
LOG_SINK=stdout
# Path for file sink (relative to project root)
LOG_FILE=logs/nexus.log
# Loki push URL (for LOG_SINK=loki)
LOKI_URL=http://loki:3100

# ── Backup ────────────────────────────────────────────────────
# Enable automated daily backups
BACKUP_ENABLED=false
# S3 bucket for offsite backup storage
BACKUP_S3_BUCKET=my-nexus-backups
BACKUP_S3_PREFIX=nexus-backups
# Cron expression for backup schedule (default: daily at 3am)
BACKUP_CRON=0 3 * * *

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Comma-separated CORS origins. Set to your actual domain in production.
# DO NOT use * in production — it disables credentials and is insecure.
CORS_ORIGINS=https://your-domain.com

# ── Auth ──────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=
# Require authentication for all API endpoints
AUTH_REQUIRED=false
# Rate limit: requests per minute per IP
RATE_LIMIT_RPM=60

# ── Slack (optional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Zendesk (optional) ────────────────────────────────────────
ZENDESK_API_KEY=
ZENDESK_SUBDOMAIN=

# ── ServiceNow (optional) ─────────────────────────────────────
SERVICENOW_INSTANCE=
SERVICENOW_API_KEY=

# ── Domain (for docker-compose Caddy) ─────────────────────────
# Set to your domain for automatic HTTPS, or leave as :80 for local dev.
DOMAIN=:80
POSTGRES_PASSWORD=nexus
